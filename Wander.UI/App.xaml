<Application x:Class="Wander.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- VaultWares Base Colors (Dark Mode Defaults) -->
        <Color x:Key="VaultBaseColor">#002B36</Color>
        <Color x:Key="VaultPaperColor">#FDF6E3</Color>
        <Color x:Key="VaultGoldColor">#CC9B21</Color>
        <Color x:Key="VaultCyanColor">#21B8CC</Color>
        <Color x:Key="VaultGreenColor">#4ECC21</Color>
        <Color x:Key="VaultBurgundyColor">#A63D40</Color>
        <Color x:Key="VaultSlateColor">#4A5459</Color>
        <Color x:Key="VaultMutedColor">#586E75</Color>

        <!-- Dynamic Brushes for Theme Switching -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource VaultBaseColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#073642" />
        <SolidColorBrush x:Key="TextBrush" Color="#FDF6E3" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource VaultMutedColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource VaultGoldColor}" />
        <SolidColorBrush x:Key="InteractiveBrush" Color="{StaticResource VaultCyanColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource VaultSlateColor}" />

        <!-- Base Typography -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semilight, Segoe UI, Inter, sans-serif"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Semilight, Segoe UI, Inter, sans-serif"/>
            <Setter Property="Background" Value="{DynamicResource InteractiveBrush}"/>
            <Setter Property="Foreground" Value="#002B36"/> <!-- High contrast inverse text -->
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Application.Resources>
</Application>
