<Window x:Class="Wander.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VaultWares Wander" Height="450" Width="600"
        Background="{DynamicResource BackgroundBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <!-- Using text as fallback for VaultWares minimal branding -->
            <TextBlock Text="VaultWares | Wander" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button x:Name="LangToggleBtn" Content="EN / QC" Click="LangToggle_Click" Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,10,0"/>
                <Button x:Name="ThemeToggleBtn" Content="Toggle Theme" Click="ThemeToggle_Click" Background="Transparent" Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
        </DockPanel>

        <!-- Main Content -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="20">
            <StackPanel>
                <TextBlock x:Name="SettingsTitle" Text="Synchronization Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <TextBlock x:Name="FolderLabel" Text="Local Sync Directory:" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock x:Name="SyncFolderPath" Text="C:\WanderSync" Foreground="{DynamicResource TextBrush}"/>
                    </Border>
                    
                    <Button x:Name="BrowseBtn" Content="Browse..." Grid.Column="1" Click="Browse_Click"/>
                </Grid>

                <TextBlock x:Name="NetworkLabel" Text="Network Status: Checking..." Foreground="{DynamicResource VaultCyanColor}" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Status / Start Button -->
        <Button x:Name="StartSyncBtn" Content="Start Wander Engine" Grid.Row="3" HorizontalAlignment="Right" Click="StartSync_Click"/>
    </Grid>
</Window>
