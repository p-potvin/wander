<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Wander.Dashboard.MainWindow"
        Title="VaultWares — Wander"
        Width="920" Height="600"
        Icon="/Assets/wander-gold.png"
        Background="{StaticResource VaultWarmBg}">

    <!-- Warm frame (the desk) wrapping the console core (the screen) -->
    <Grid Margin="20" RowDefinitions="Auto,*">

        <!-- Header: warm chrome -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="10" DockPanel.Dock="Left">
                <Image Source="/Assets/wander-gold.png" Width="26" Height="26" VerticalAlignment="Center"/>
                <TextBlock Text="VaultWares" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource VaultInk}" VerticalAlignment="Center"/>
                <Rectangle Width="2" Height="20" Fill="{StaticResource VaultConsoleGold}" VerticalAlignment="Center"/>
                <TextBlock Text="Wander" FontSize="20" FontWeight="Light"
                           Foreground="{StaticResource VaultInkSecondary}" VerticalAlignment="Center"/>
            </StackPanel>
            <Border DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{StaticResource VaultWarmRaised}" BorderBrush="{StaticResource VaultWarmBorderSubtle}"
                    BorderThickness="1" CornerRadius="12" Padding="10,4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="{StaticResource VaultWarmMuted}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Starting…" FontSize="12"
                               Foreground="{StaticResource VaultInkSecondary}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DockPanel>

        <Grid Grid.Row="1" ColumnDefinitions="320,16,*">

            <!-- Left column: warm document cards (structural frame) -->
            <StackPanel Grid.Column="0" Spacing="14">

                <Border Background="{StaticResource VaultWarmRaised}" CornerRadius="10" Padding="16"
                        BorderBrush="{StaticResource VaultWarmBorderSubtle}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="THIS NODE" FontSize="11" LetterSpacing="1.5"
                                   Foreground="{StaticResource VaultInkSecondary}"/>
                        <TextBlock x:Name="NodeName" Text="—" FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource VaultInk}"/>
                        <TextBlock x:Name="NodeAddress" Text="—" FontSize="12"
                                   FontFamily="{StaticResource VaultFontMono}"
                                   Foreground="{StaticResource VaultInkSecondary}"/>
                        <Rectangle Height="1" Fill="{StaticResource VaultWarmBorderSubtle}" Margin="0,8"/>
                        <TextBlock Text="Sync folder" FontSize="11" Foreground="{StaticResource VaultInkSecondary}"/>
                        <TextBlock x:Name="SyncRootText" Text="—" FontSize="11" TextWrapping="Wrap"
                                   FontFamily="{StaticResource VaultFontMono}"
                                   Foreground="{StaticResource VaultInkSecondary}"/>
                        <TextBlock x:Name="FileCount" Text="—" FontSize="13" Margin="0,4,0,0"
                                   Foreground="{StaticResource VaultInk}"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VaultWarmRaised}" CornerRadius="10" Padding="16"
                        BorderBrush="{StaticResource VaultWarmBorderSubtle}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="TAILNET PEERS" FontSize="11" LetterSpacing="1.5"
                                   Foreground="{StaticResource VaultInkSecondary}"/>
                        <ItemsControl x:Name="PeersList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3">
                                        <Ellipse Width="8" Height="8" Fill="{StaticResource VaultSignalOnline}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource VaultInk}" FontSize="13"/>
                                        <TextBlock Text="{Binding Ip}" Foreground="{StaticResource VaultInkSecondary}" FontSize="11"
                                                   FontFamily="{StaticResource VaultFontMono}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NoPeersText" Text="No online peers found."
                                   Foreground="{StaticResource VaultInkSecondary}" FontSize="12" IsVisible="False"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource VaultWarmRaised}" CornerRadius="10" Padding="16"
                        BorderBrush="{StaticResource VaultWarmBorderSubtle}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="CONFLICTS" FontSize="11" LetterSpacing="1.5"
                                   Foreground="{StaticResource VaultInkSecondary}"/>
                        <ItemsControl x:Name="ConflictsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3">
                                        <Ellipse Width="8" Height="8" Fill="{StaticResource VaultSignalWarning}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding}" Foreground="{StaticResource VaultInk}" FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NoConflictsText" Text="No unresolved conflict copies."
                                   Foreground="{StaticResource VaultInkSecondary}" FontSize="12"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Console core: where the action happens -->
            <Border Grid.Column="2" Background="{StaticResource VaultConsoleBg}" CornerRadius="10"
                    BorderBrush="{StaticResource VaultConsoleBorderSubtle}" BorderThickness="1" Padding="2">
                <Border Background="{StaticResource VaultConsoleSurface}" CornerRadius="8" Padding="16">
                    <Grid RowDefinitions="Auto,*">
                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <Image DockPanel.Dock="Left" Source="/Assets/wander-console.png" Width="16" Height="16"
                                   Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.85"/>
                            <TextBlock DockPanel.Dock="Left" Text="ACTIVITY" FontSize="11" LetterSpacing="1.5"
                                       Foreground="{StaticResource VaultConsoleGold}" VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" Text="live"
                                       FontSize="11" FontFamily="{StaticResource VaultFontMono}"
                                       Foreground="{StaticResource VaultSignalOnline}"/>
                        </DockPanel>
                        <ScrollViewer Grid.Row="1">
                            <ItemsControl x:Name="ActivityList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="60,68,*" Margin="0,3">
                                            <TextBlock Grid.Column="0" Text="{Binding Time}" FontSize="11"
                                                       FontFamily="{StaticResource VaultFontMono}"
                                                       Foreground="{StaticResource VaultConsoleText}"
                                                       VerticalAlignment="Top" Margin="0,1,0,0"/>
                                            <Border Grid.Column="1" Background="{StaticResource VaultConsoleRaised}" CornerRadius="4"
                                                    Padding="6,1" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Category}" FontSize="10"
                                                           FontFamily="{StaticResource VaultFontMono}"
                                                           Foreground="{StaticResource VaultConsoleGold}"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Message}" FontSize="12" TextWrapping="Wrap"
                                                       FontFamily="{StaticResource VaultFontMono}"
                                                       Foreground="{StaticResource VaultConsoleTextSecondary}" Margin="8,1,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Border>

        </Grid>
    </Grid>
</Window>
