<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Wander.Dashboard.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- vaultwares-themes/vaultwares-revisited/ports/avalonia — the shared token
                     set. Do not hardcode hex values here; add new tokens upstream if missing. -->
                <ResourceInclude Source="avares://Wander.Dashboard/Assets/VaultTokens.axaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Consumer-declared, per vaultwares-revisited/TOKENS.md: the warm-mode
                 foreground ("ink") is not a shared revisited.css token. -->
            <SolidColorBrush x:Key="VaultInk">#161320</SolidColorBrush>
            <SolidColorBrush x:Key="VaultInkSecondary">#99161320</SolidColorBrush>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/wander-gold.png" ToolTipText="VaultWares — Wander">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Open dashboard" Click="TrayOpen_Click"/>
                        <NativeMenuItem Header="Pause syncing" Click="TrayPause_Click"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Quit Wander" Click="TrayQuit_Click"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
