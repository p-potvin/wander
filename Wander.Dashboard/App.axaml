<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Wander.Dashboard.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <!-- vaultwares-revisited tokens (vaultwares-themes/vaultwares-revisited/TOKENS.md).
             Console and warm coexist: warm is the structural frame (the desk),
             console is the operational core (the screen). -->

        <!-- Warm mode: the frame -->
        <SolidColorBrush x:Key="VaultWarmBg">#F5F1E8</SolidColorBrush>
        <SolidColorBrush x:Key="VaultWarmRaised">#FCFAF5</SolidColorBrush>
        <SolidColorBrush x:Key="VaultWarmMuted">#ECE5D8</SolidColorBrush>
        <SolidColorBrush x:Key="VaultWarmBorderSubtle">#14161320</SolidColorBrush>
        <SolidColorBrush x:Key="VaultInk">#161320</SolidColorBrush>
        <SolidColorBrush x:Key="VaultInkSecondary">#99161320</SolidColorBrush>

        <!-- Console mode: the operational core -->
        <SolidColorBrush x:Key="VaultConsoleBg">#0b0813</SolidColorBrush>
        <SolidColorBrush x:Key="VaultConsoleSurface">#13101c</SolidColorBrush>
        <SolidColorBrush x:Key="VaultConsoleRaised">#2A2340</SolidColorBrush>
        <SolidColorBrush x:Key="VaultConsoleElevated">#453763</SolidColorBrush>
        <SolidColorBrush x:Key="VaultConsoleText">#a394cc</SolidColorBrush>
        <SolidColorBrush x:Key="VaultConsoleTextSecondary">#B8EDE6FF</SolidColorBrush>
        <SolidColorBrush x:Key="VaultConsoleBorderSubtle">#0FFFFFFF</SolidColorBrush>

        <!-- Brand accents -->
        <SolidColorBrush x:Key="VaultConsoleGold">#D6A441</SolidColorBrush>
        <SolidColorBrush x:Key="VaultConsoleViolet">#B07CFF</SolidColorBrush>

        <!-- Signal palette -->
        <SolidColorBrush x:Key="VaultSignalOnline">#6BE675</SolidColorBrush>
        <SolidColorBrush x:Key="VaultSignalRelay">#55D6FF</SolidColorBrush>
        <SolidColorBrush x:Key="VaultSignalSync">#B07CFF</SolidColorBrush>
        <SolidColorBrush x:Key="VaultSignalWarning">#F0B94B</SolidColorBrush>
        <SolidColorBrush x:Key="VaultSignalAlert">#FF6B7A</SolidColorBrush>

        <FontFamily x:Key="VaultMono">JetBrains Mono, Cascadia Mono, Consolas, monospace</FontFamily>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/wander-gold.png" ToolTipText="VaultWares — Wander">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Open dashboard" Click="TrayOpen_Click"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Quit Wander" Click="TrayQuit_Click"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
